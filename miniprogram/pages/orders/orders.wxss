/* ===== 订单页（可爱风） ===== */

.orders-page {
  min-height: 100vh;
  padding: 34rpx 28rpx 80rpx;
  background:
    radial-gradient(ellipse at 80% 10%, rgba(255, 123, 137, 0.08), transparent 240rpx),
    radial-gradient(ellipse at 20% 90%, rgba(255, 184, 84, 0.08), transparent 220rpx),
    linear-gradient(175deg, #FFF5EC 0%, #FFF0E5 40%, #FFF8F2 100%);
  color: #5C3D2E;
}

.orders-page::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  opacity: 0.10;
  background-image:
    radial-gradient(circle, #FFB854 1.5rpx, transparent 1.5rpx),
    radial-gradient(circle, #FF7B89 1rpx, transparent 1rpx);
  background-size: 80rpx 80rpx, 120rpx 120rpx;
  background-position: 0 0, 40rpx 60rpx;
}

/* ===== 空订单 ===== */
.orders-empty {
  min-height: 72vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  position: relative;
  z-index: 1;
}

.empty-mark {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 30rpx;
  border-radius: 90rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 3rpx solid rgba(255, 180, 160, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  box-shadow: 0 12rpx 30rpx rgba(255, 150, 140, 0.12);
}

.loading-mark {
  animation: orderBreathe 1000ms ease-in-out infinite;
}

@keyframes orderBreathe {
  0% { transform: scale(1); opacity: 0.75; }
  50% { transform: scale(1.05); opacity: 1; }
  100% { transform: scale(1); opacity: 0.75; }
}

.empty-title {
  color: #5C3D2E;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.2;
}

.empty-copy {
  width: 500rpx;
  margin-top: 16rpx;
  font-size: 27rpx;
  line-height: 1.55;
  color: #A08070;
}

.empty-button {
  width: 360rpx;
  margin-top: 36rpx;
}

/* ===== 订单头部 ===== */
.orders-header {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 18rpx;
  margin-bottom: 30rpx;
  position: relative;
  z-index: 1;
}

.orders-title-block {
  flex: 1;
  min-width: 0;
}

.eyebrow {
  display: block;
  color: #A08070;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 700;
  white-space: nowrap;
  word-break: keep-all;
}

.orders-title {
  display: block;
  margin-top: 8rpx;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.2;
  color: #5C3D2E;
  white-space: nowrap;
  word-break: keep-all;
}

.header-actions {
  display: flex;
  align-items: center;
  width: 100%;
  gap: 12rpx;
}

.refresh-button,
.manage-button {
  flex: 1;
  width: auto;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0;
  margin: 0;
  border-radius: 30rpx;
  color: #FF7B89;
  background: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(255, 180, 160, 0.18);
  font-size: 23rpx;
  font-weight: 800;
  box-shadow: 0 4rpx 12rpx rgba(255, 150, 140, 0.08);
}

.manage-button.active {
  color: #FFF;
  background: linear-gradient(135deg, #FF7B89 0%, #FF9AAE 100%);
  border-color: #FF7B89;
}

.refresh-button::after,
.manage-button::after,
.batch-ghost::after,
.batch-delete::after,
.delete-order-btn::after {
  border: 0;
}

/* 批量操作栏 */
.batch-bar {
  min-height: 78rpx;
  margin-bottom: 18rpx;
  padding: 0 14rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(255, 180, 160, 0.18);
  position: relative;
  z-index: 1;
}

.batch-ghost,
.batch-delete {
  width: 142rpx;
  height: 54rpx;
  line-height: 54rpx;
  padding: 0;
  margin: 0;
  border-radius: 27rpx;
  font-size: 23rpx;
  font-weight: 900;
}

.batch-ghost {
  color: #FF7B89;
  background: rgba(255, 123, 137, 0.08);
}

.batch-count {
  flex: 1;
  min-width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #A08070;
  font-size: 24rpx;
  line-height: 1.2;
  white-space: nowrap;
  word-break: keep-all;
}

.batch-delete {
  color: #FFFFFF;
  background: linear-gradient(135deg, #FF7B89 0%, #FF9AAE 100%);
}

/* ===== 订单列表 ===== */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  position: relative;
  z-index: 1;
}

.order-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #FFFBF7;
  border: 2rpx solid rgba(255, 200, 180, 0.15);
  box-shadow: 0 10rpx 28rpx rgba(255, 150, 140, 0.10);
}

.order-card.selected {
  border-color: rgba(255, 123, 137, 0.5);
  background: #FFF5F2;
  box-shadow: 0 10rpx 28rpx rgba(255, 123, 137, 0.14);
}

.order-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.select-dot {
  width: 38rpx;
  height: 38rpx;
  flex: 0 0 38rpx;
  border-radius: 19rpx;
  box-sizing: border-box;
  border: 3rpx solid rgba(255, 180, 160, 0.3);
  background: #FFFBF7;
}
.select-dot.checked {
  border-color: #FF7B89;
  background: #FF7B89;
  box-shadow: inset 0 0 0 8rpx #FFF;
}

.order-main {
  flex: 1;
  min-width: 0;
}

.order-index {
  width: 50rpx;
  height: 50rpx;
  flex: 0 0 50rpx;
  border-radius: 25rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFF;
  background: linear-gradient(135deg, #FF7B89 0%, #FF9AAE 100%);
  font-size: 22rpx;
  font-weight: 900;
  box-shadow: 0 4rpx 12rpx rgba(255, 123, 137, 0.2);
}

.order-id {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.3;
  color: #5C3D2E;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-time {
  display: block;
  margin-top: 6rpx;
  color: #A08070;
  font-size: 22rpx;
  line-height: 1.35;
}

.status {
  flex: 0 0 auto;
  min-width: 104rpx;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 24rpx;
  text-align: center;
  background: rgba(255, 184, 84, 0.15);
  color: #E8A030;
  font-size: 22rpx;
  font-weight: 900;
}

.status.status-cancel-pending {
  background: rgba(160, 128, 112, 0.12);
  color: #8B6F5E;
}

.status.status-cancelled {
  background: rgba(255, 123, 137, 0.10);
  color: #C9606E;
}

.status.status-rejected {
  background: rgba(160, 128, 112, 0.10);
  color: #8B6F5E;
}

.order-summary-strip {
  display: flex;
  gap: 16rpx;
  margin: 22rpx 0 16rpx;
}

.order-summary-strip > view {
  flex: 1;
  min-height: 94rpx;
  padding: 14rpx 20rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #FFF8F3;
  border: 1rpx solid rgba(255, 200, 180, 0.12);
}

.summary-label {
  display: block;
  color: #B89888;
  font-size: 22rpx;
  line-height: 1.2;
}

.summary-value {
  display: block;
  margin-top: 6rpx;
  color: #5C3D2E;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.15;
}

.summary-value.price {
  color: #FF7B89;
}

.dish-list {
  padding-top: 4rpx;
}

.dish-row,
.order-total {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 12rpx;
  color: #8B6F5E;
  font-size: 26rpx;
  line-height: 1.4;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.cancel-request-btn {
  height: 54rpx;
  line-height: 54rpx;
  padding: 0 24rpx;
  margin: 0;
  border-radius: 27rpx;
  color: #8B6F5E;
  background: rgba(160, 128, 112, 0.08);
  border: 2rpx solid rgba(160, 128, 112, 0.12);
  font-size: 23rpx;
  font-weight: 800;
}

.cancel-request-btn::after {
  border: 0;
}

.cancel-hint {
  text-align: right;
  font-size: 23rpx;
  color: #A08070;
  padding: 8rpx 0;
}

.cancel-hint.cancelled {
  color: #C9606E;
}

.cancel-hint.rejected {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  color: #8B6F5E;
}

.retry-cancel-btn {
  height: 50rpx;
  line-height: 50rpx;
  padding: 0 20rpx;
  margin: 0;
  border-radius: 25rpx;
  color: #FF7B89;
  background: rgba(255, 123, 137, 0.08);
  font-size: 22rpx;
  font-weight: 800;
  border: 1rpx solid rgba(255, 123, 137, 0.15);
}

.retry-cancel-btn::after {
  border: 0;
}

.dish-info {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dish-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-count {
  flex: 0 0 auto;
  color: #B89888;
  font-size: 23rpx;
}

.dish-price {
  flex: 0 0 auto;
  color: #FF7B89;
  font-weight: 900;
}

.order-total {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid rgba(255, 180, 160, 0.2);
  color: #5C3D2E;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.3;
}
