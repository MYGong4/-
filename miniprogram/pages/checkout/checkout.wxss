/* ===== 结算页（可爱风） ===== */

.checkout-page {
  padding-bottom: 60rpx;
  position: relative;
  z-index: 1;
}

.checkout-page::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: -1;
  opacity: 0.10;
  background-image:
    radial-gradient(circle, #FFB854 1.5rpx, transparent 1.5rpx),
    radial-gradient(circle, #FF7B89 1rpx, transparent 1rpx);
  background-size: 80rpx 80rpx, 120rpx 120rpx;
  background-position: 0 0, 40rpx 60rpx;
}

/* ===== 汇总卡片 ===== */
.summary-card,
.form-card,
.order-items {
  margin-bottom: 22rpx;
  padding: 28rpx 24rpx;
  border-radius: 20rpx;
  background: #FFFBF7;
  border: 2rpx solid rgba(255, 200, 180, 0.15);
  box-shadow: 0 8rpx 22rpx rgba(255, 150, 140, 0.08);
}

.summary-title,
.form-title {
  display: block;
  margin-bottom: 22rpx;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
  color: #5C3D2E;
  padding-left: 12rpx;
}

.summary-title::before {
  content: "🧾 ";
  font-size: 26rpx;
}

.form-title::before {
  content: "📝 ";
  font-size: 26rpx;
}

.summary-row,
.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
  color: #8B6F5E;
  font-size: 28rpx;
  line-height: 1.45;
}

.summary-row.total {
  margin-bottom: 0;
  padding-top: 18rpx;
  border-top: 2rpx solid rgba(255, 180, 160, 0.2);
  color: #5C3D2E;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.3;
}

/* ===== 表单 ===== */
.field,
.textarea {
  width: 100%;
  margin-bottom: 18rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #FFF8F3;
  color: #5C3D2E;
  font-size: 28rpx;
  line-height: 1.4;
  border: 2rpx solid rgba(255, 200, 180, 0.18);
}

.field {
  height: 88rpx;
}

.textarea {
  height: 160rpx;
  padding-top: 22rpx;
  padding-bottom: 22rpx;
}

.field:focus,
.textarea:focus {
  border-color: rgba(255, 123, 137, 0.4);
  background: #FFFBF7;
}

.item-row:last-child {
  margin-bottom: 0;
}

.submit-button {
  margin-top: 16rpx;
}

.submit-button::after { border: 0; }
